// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  employeeNumber    String          @unique
  name              String
  brand             String          // AGRA | NOYA | HQ
  storeId           String          
  storeName         String
  department        String
  role              String          // STAFF | MANAGER | HR_ADMIN
  employmentType    String
  status            String          // ACTIVE | ON_LEAVE | RESIGNED
  phone             String?
  email             String?
  address           String?
  joinedAt          DateTime        @default(now())
  resignedAt        DateTime?
  passwordHash      String
  twoFactorSecret   String?
  is2faEnabled      Boolean         @default(false)
  magicLinkToken    String?
  magicLinkExpires  DateTime?
  passkeys          Passkey[]
  
  // Real Data Fields
  residentNumber    String?
  birthDate         String?         // YYYY-MM-DD
  bankName          String?
  accountNumber     String?
  baseSalary        Float           @default(0)
  hourlyWage        Float           @default(0)
  jobTitle          String?
  idCardUrl         String?
  bankbookUrl       String?
  
  // Health Certificate (보건증)
  healthCertificateUrl String?
  healthCertificateExp DateTime?
  healthCertRequired   Boolean         @default(true)

  // Granular Permissions
  canManageNotices      Boolean         @default(false)
  canManageLeaves       Boolean         @default(false)
  canApplyLeaves        Boolean         @default(false)
  canManagePayroll      Boolean         @default(false)
  canManageLeavePolicy  Boolean         @default(false)
  canManageResignations Boolean         @default(false)
  canManageCertificates Boolean         @default(false)
  canManageEmployees    Boolean         @default(false)
  canManageKnowledge    Boolean         @default(false)
  canManageIncidents    Boolean         @default(false)
  canManageStores       Boolean         @default(false)
  canManageHrInfo       Boolean         @default(false)

  payrolls          Payroll[]
  leaves            Leave[]
  leaveRequests     LeaveRequest[]
  certificates      CertificateRecord[]
  resignations      ResignationRecord[]
  approvalSteps     ApprovalStep[]
  incidentReports   IncidentReport[]
}

model Payroll {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  paymentMonth    String   // e.g. "2026-02"
  baseSalary      Float
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  netPay          Float
  status          String   // DRAFT | PAID
}

model Leave {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  year            Int
  totalDays       Float    @default(15)
  usedDays        Float    @default(0)
}

model LeaveRequest {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  leaveType       String   @default("ANNUAL") // ANNUAL | HALF_DAY | QUARTER_DAY | CONGRATULATORY | OFFICIAL | MATERNITY | PARENTAL | UNPAID | OTHER
  leaveSubType    String?  // Specific reason for congratulatory or other, e.g., '본인 결혼', '산재'
  startDate       DateTime
  endDate         DateTime
  daysRequested   Float
  reason          String?
  attachmentUrl   String?  // Base64 or URL for congratulatory evidence
  rejectionReason String?  // Added for HR forced rejection reasoning
  approverNote    String?  // Added for optional memos during approval/rejection
  status          String   // PENDING | APPROVED | REJECTED
}

model KnowledgeDocument {
  id              String   @id @default(uuid())
  category        String
  title           String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notice {
  id              String   @id @default(uuid())
  category        String   @default("일반 공지") // 일반 공지 | 인사 관련 서식 파일 | 인사 관련 매뉴얼 | 업무 마감일 | 매장 보험 증서
  title           String
  content         String
  author          String   @default("인사팀")
  isImportant     Boolean  @default(false)
  attachmentUrl   String?  // Base64 encoded string or URL
  attachmentName  String?  // Original file name
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CertificateRecord {
  id                 String   @id @default(uuid())
  employeeId         String?
  employee           User?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  
  // Snapshot for permanent storage
  employeeName       String?
  employeeNumber     String?
  employeeStore      String?
  employeeDepartment String?
  employeeJobTitle   String?
  
  type               String   // e.g., "CERTIFICATE_OF_EMPLOYMENT"
  purpose            String   // e.g., "은행 제출용"
  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED
  corporateName      String?  // The dynamically chosen Legal Name
  corporateAddress   String?  // The dynamically chosen Legal Address
  issuedAt           DateTime @default(now())
}

model LeavePolicy {
  id              String   @id @default(uuid())
  type            String   @unique // e.g., "ANNUAL", "CONGRATULATORY", "UNPAID"
  name            String   // e.g., "연차", "경조 휴가", "무급 휴가"
  description     String?
  defaultDays     Float    @default(0)
  isPaid          Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ResignationRecord {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  resignationDate DateTime
  reason          String
  contactAfterResignation String? // Required contact number
  signatureData   String   // Base64 string of the signature canvas
  paymentAgreement String? // "AGREE"
  paymentSignature String? // Base64 string of the agreement signature
  approverNote    String?  // Optional memo during approval/rejection
  rejectionReason String?  // Mandatory reason when rejected
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id        String   @id @default("global")
  data      Json
  updatedAt DateTime @updatedAt
}

model Store {
  id        String   @id @default(cuid())
  brand     String?
  erpName   String?
  name      String   @unique
  businessRegistration String?
  address   String
  contact   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HrInfo {
  id           String   @id @default(cuid())
  erpStoreName String
  brand        String
  department   String
  workingStore String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ApprovalStep {
  id              String   @id @default(uuid())
  documentType    String   // "LEAVE" | "RESIGNATION" | "INCIDENT"
  documentId      String   
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String   // "APPROVER" | "REFERENCE"
  status          String   @default("WAITING") // WAITING | PENDING | APPROVED | REJECTED
  order           Int      // 1, 2, 3...
  isFinal         Boolean  @default(false)     // '전결' 여부
  approvedAt      DateTime?
  rejectionReason String?
  approverNote    String?
  createdAt       DateTime @default(now())
}

model IncidentReport {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  type            String   // "INCIDENT" | "EXPLANATION"
  incidentDate    DateTime
  title           String   @default("")
  pledge          String   @db.Text
  violation       String   @db.Text
  content         String?  @db.Text
  attachmentUrl   String?
  signatureData   String?  @db.Text
  status          String   @default("PENDING")
  approverNote    String?  @db.Text
  rejectionReason String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id              String   @id @default(uuid())
  actorId         String?  
  actorName       String?  
  actionType      String   
  resource        String   
  resourceId      String?  
  details         String?  @db.Text
  createdAt       DateTime @default(now())
}

model Passkey {
  id                   String   @id @default(uuid())
  credentialID         String   @unique
  credentialPublicKey  Bytes
  counter              BigInt
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
