// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String          @id @default(uuid())
  employeeNumber    String          @unique
  name              String
  brand             String          // AGRA | NOYA | HQ
  storeId           String          
  storeName         String
  department        String
  role              String          // STAFF | MANAGER | HR_ADMIN
  employmentType    String
  status            String          // ACTIVE | ON_LEAVE | RESIGNED
  phone             String?
  email             String?
  address           String?
  joinedAt          DateTime        @default(now())
  passwordHash      String
  twoFactorSecret   String?
  is2faEnabled      Boolean         @default(false)
  
  // Real Data Fields
  residentNumber    String?
  birthDate         String?         // YYYY-MM-DD
  bankName          String?
  accountNumber     String?
  baseSalary        Float           @default(0)
  hourlyWage        Float           @default(0)
  jobTitle          String?
  idCardUrl         String?
  bankbookUrl       String?
  
  // Health Certificate (보건증)
  healthCertificateUrl String?
  healthCertificateExp DateTime?

  // Granular Permissions
  canManageNotices  Boolean         @default(false)
  canManageLeaves   Boolean         @default(false)
  canManagePayroll  Boolean         @default(false)

  payrolls          Payroll[]
  leaves            Leave[]
  leaveRequests     LeaveRequest[]
  certificates      CertificateRecord[]
  resignations      ResignationRecord[]
}

model Payroll {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  paymentMonth    String   // e.g. "2026-02"
  baseSalary      Float
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  netPay          Float
  status          String   // DRAFT | PAID
}

model Leave {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  year            Int
  totalDays       Float    @default(15)
  usedDays        Float    @default(0)
}

model LeaveRequest {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  leaveType       String   @default("ANNUAL") // ANNUAL | HALF_DAY | QUARTER_DAY | CONGRATULATORY | OFFICIAL | MATERNITY | PARENTAL | UNPAID | OTHER
  leaveSubType    String?  // Specific reason for congratulatory or other, e.g., '본인 결혼', '산재'
  startDate       DateTime
  endDate         DateTime
  daysRequested   Float
  reason          String?
  attachmentUrl   String?  // Base64 or URL for congratulatory evidence
  rejectionReason String?  // Added for HR forced rejection reasoning
  status          String   // PENDING | APPROVED | REJECTED
}

model KnowledgeDocument {
  id              String   @id @default(uuid())
  category        String
  title           String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Notice {
  id              String   @id @default(uuid())
  title           String
  content         String
  author          String   @default("인사팀")
  isImportant     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CertificateRecord {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  type            String   // e.g., "CERTIFICATE_OF_EMPLOYMENT"
  purpose         String   // e.g., "은행 제출용"
  issuedAt        DateTime @default(now())
}

model LeavePolicy {
  id              String   @id @default(uuid())
  type            String   @unique // e.g., "ANNUAL", "CONGRATULATORY", "UNPAID"
  name            String   // e.g., "연차", "경조 휴가", "무급 휴가"
  description     String?
  defaultDays     Float    @default(0)
  isPaid          Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ResignationRecord {
  id              String   @id @default(uuid())
  employeeId      String
  employee        User     @relation(fields: [employeeId], references: [id])
  resignationDate DateTime
  reason          String
  signatureData   String   // Base64 string of the signature canvas
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
